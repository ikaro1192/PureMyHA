clusters:
  - name: main
    nodes:
      - host: db1
        port: 3306
      - host: db2
        port: 3306
    credentials:
      user: puremyha
      # password_file must be a regular file (not a symlink), owned by root or
      # the user running puremyhad, and readable only by its owner (mode 0600
      # or 0400). The daemon refuses to start otherwise.
      password_file: /etc/puremyha/mysql.pass
    replication_credentials:           # optional; falls back to credentials if omitted
      user: repl
      password_file: /etc/puremyha/repl.pass
    # tls:                                             # optional per-cluster TLS for MySQL connections
    #   mode: disabled                                 # disabled | skip-verify | verify-ca | verify-full. Default: disabled
    #   min_version: "1.2"                             # optional; "1.2" (default, allows TLS 1.2+) | "1.3" (TLS 1.3 only)
    #   ca_cert: /etc/puremyha/tls/ca-cert.pem        # required for verify-ca / verify-full
    #   client_cert: /etc/puremyha/tls/client.pem     # optional (mutual TLS)
    #   client_key: /etc/puremyha/tls/client-key.pem  # optional (mutual TLS)
    # failover:                                    # optional; overrides global failover defaults per-cluster
    #   candidate_priority:                        # must be set per-cluster (hostnames differ per cluster)
    #     - host: db2                              # ordered by priority; auto-selected by GTID if omitted
    #   never_promote:                             # must be set per-cluster; hosts excluded from promotion
    #     - db3-analytics                          # e.g. analytics replicas, backup-only nodes, delayed replicas
    #                                              # These nodes continue to be monitored and replicate normally.
    #                                              # `switchover --to <never_promote_host>` is also rejected.
    # monitoring / failure_detection / failover / hooks:
    #   Omitted here — values are inherited from the global section below.
    #   Any of these can be specified per-cluster to override the global defaults.
    #   Note: failover.candidate_priority and failover.never_promote reference hostnames and
    #   must always be set per-cluster; they are not allowed in the global section.

global:
  monitoring:
    interval: 3s
    connect_timeout: 2s
    replication_lag_warning: 10s
    replication_lag_critical: 30s
    discovery_interval: 300s   # optional; 0s = disabled. Default: 300s
    connect_retries: 1         # optional; total connection attempts per probe (1 = no retry). Default: 1
    connect_retry_backoff: 1s  # optional; initial backoff between retries, doubles each attempt, capped at connect_timeout. Default: 1s
  failure_detection:
    recovery_block_period: 3600s   # block auto-failover for this long after a failover
    consecutive_failures_for_dead: 3  # require N consecutive probe failures before marking a node dead (default: 3)
  failover:
    auto_failover: true
    min_replicas_for_failover: 1  # quorum: minimum number of replicas that must unanimously confirm IO=No
                                  # before declaring DeadSource. If fewer witnesses are available the cluster
                                  # enters InsufficientQuorum and failover is withheld. Default: 1
    wait_for_relay_log_apply_timeout: 60s  # optional; default: 60s
    auto_fence: false              # optional; set to true to automatically fence split-brain nodes. Default: false
                                   # When enabled, on SplitBrainSuspected the node with the highest GTID count
                                   # is kept writable; all other sources get SET GLOBAL super_read_only = ON.
                                   # Use `puremyha unfence --host <host>` to clear super_read_only manually.
    max_replica_lag_for_candidate: 30  # optional; replicas with lag > this value (seconds) are excluded from
                                       # failover candidate selection. Default: no limit.
                                       # Note: replicas reaching monitoring.replication_lag_critical also become
                                       # Lagging and are automatically excluded regardless of this setting.
    # failover_without_observed_healthy: false  # optional; if true, allows auto-failover even if the cluster
                                               # was never observed as Healthy since daemon start.
                                               # Useful when puremyhad and the source are co-located in the
                                               # same AZ and can fail simultaneously (e.g. AZ outage).
                                               # Default: false. See docs/failover.md for tradeoffs.
  hooks:
    # Each configured hook script must, at invocation time, be an absolute
    # path, a regular file (not a symlink or directory), owned by root or the
    # user running puremyhad, and must NOT have the world-writable bit set
    # (mode & 0o002 == 0). Hooks failing any check are refused; for pre-hooks
    # this aborts the failover/switchover. Recommended: chown root:root and
    # chmod 0755 on every hook script.
    pre_failover: /etc/puremyha/hooks/pre_failover.sh
    post_failover: /etc/puremyha/hooks/post_failover.sh
    pre_switchover: /etc/puremyha/hooks/pre_switchover.sh
    post_switchover: /etc/puremyha/hooks/post_switchover.sh
    on_failure_detection: /etc/puremyha/hooks/on_failure_detection.sh              # optional
    post_unsuccessful_failover: /etc/puremyha/hooks/post_unsuccessful_failover.sh  # optional
    on_fence: /etc/puremyha/hooks/on_fence.sh                                      # optional; fired after a node is auto-fenced
                                                                                    # Env: PUREMYHA_CLUSTER, PUREMYHA_OLD_SOURCE (fenced host), PUREMYHA_NEW_SOURCE (survivor host)
    on_lag_threshold_exceeded: /etc/puremyha/hooks/on_lag_threshold_exceeded.sh    # optional; fired when a replica transitions to Lagging health
                                                                                    # Env: PUREMYHA_CLUSTER, PUREMYHA_NODE, PUREMYHA_LAG_SECONDS, PUREMYHA_TIMESTAMP
    on_lag_threshold_recovered: /etc/puremyha/hooks/on_lag_threshold_recovered.sh  # optional; fired when a replica recovers from Lagging health
                                                                                    # Env: PUREMYHA_CLUSTER, PUREMYHA_NODE, PUREMYHA_TIMESTAMP
    on_topology_drift: /etc/puremyha/hooks/on_topology_drift.sh                    # optional; fired on transition to topology drift state (False→True only)
                                                                                    # Env: PUREMYHA_CLUSTER, PUREMYHA_DRIFT_TYPE (missing_node|unexpected_node|replica_count_below_threshold),
                                                                                    #      PUREMYHA_DRIFT_DETAILS, PUREMYHA_TIMESTAMP
    hook_timeout: 30s                                                              # max wall-clock time per hook; process group is SIGTERM'd then SIGKILL'd on overrun. Default: 30s

logging:                               # optional logging configuration
  log_file: /var/log/puremyha.log    # default: /var/log/puremyha.log
  log_level: info                    # minimum log level: debug | info | warn | error. Default: info

http:                                  # optional HTTP health check server
  enabled: false                     # default: false — set to true to expose endpoints
  listen_address: "127.0.0.1"        # default: 127.0.0.1 (use 0.0.0.0 for all interfaces)
  port: 8080                         # default: 8080
  # Endpoints (read-only, GET only):
  #   GET /health                 → 200 {"status":"ok"} / 503 {"status":"degraded"}
  #   GET /cluster/:name/status   → ClusterStatus JSON   (readiness probe / LB check)
  #   GET /cluster/:name/topology → ClusterTopologyView JSON
  #   GET /metrics                → Prometheus text format metrics (all clusters)
